{
  "name": "messagesend-workspace",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "lint": "oxlint . --deny-warnings",
    "lint:fix": "oxlint . --fix",
    "build:core": "bun run --filter @noor-dev/messagesend-core build",
    "build:cli": "bun run --filter @noor-dev/messagesend build",
    "build:local-mcp": "bun run --filter @noor-dev/messagesend-mcp build",
    "dev:cli": "bun run packages/cli/src/index.ts",
    "dev:local-mcp": "bun run packages/local-mcp/src/index.ts",
    "dev:remote-mcp": "bun run apps/remote-mcp/src/index.ts",
    "release:pack:core": "bun run --filter @noor-dev/messagesend-core pack:dry",
    "release:pack:cli": "bun run --filter @noor-dev/messagesend pack:dry",
    "release:pack:local-mcp": "bun run --filter @noor-dev/messagesend-mcp pack:dry",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3"
  }
}
